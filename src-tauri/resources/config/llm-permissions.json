{
  "version": 1,
  "levels": {
    "chat_only": {
      "label": "Chat Only",
      "description": "LLM can only send messages. No file operations.",
      "allowed_triggers": ["MESSAGE"]
    },
    "read_preview": {
      "label": "Read & Preview",
      "description": "LLM can read files and open previews. No modifications.",
      "allowed_triggers": ["MESSAGE", "PREVIEW", "READ", "LIST", "GITHUB_READ", "NOTION_READ", "SLACK_READ", "GDRIVE_READ"]
    },
    "full_access": {
      "label": "Full Access",
      "description": "LLM can read, create, edit, and delete files.",
      "allowed_triggers": ["MESSAGE", "CREATE", "DELETE", "WRITE", "INSERT", "APPEND", "PREVIEW", "READ", "RENAME", "LIST", "CREATE_DOCX", "CREATE_XLSX", "CREATE_PPTX", "CREATE_MP3", "EXPORT_PDF", "PLAN", "GITHUB_READ", "NOTION_READ", "SLACK_READ", "GDRIVE_READ"]
    }
  },
  "providers": {
    "openai": {
      "display_name": "OpenAI",
      "available_levels": ["chat_only", "read_preview", "full_access"],
      "default_level": "full_access",
      "api_mapping": {
        "chat_only": { "tool_choice": "none", "tools": [] },
        "read_preview": { "tool_choice": "auto", "tools": ["read", "list", "preview"] },
        "full_access": { "tool_choice": "auto", "tools": ["all"] }
      },
      "notes": null
    },
    "openai-codex": {
