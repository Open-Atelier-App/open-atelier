      "api_mapping": {
        "chat_only": { "function_calling_config": { "mode": "NONE" }, "function_declarations": [] },
        "read_preview": { "function_calling_config": { "mode": "AUTO" }, "function_declarations": ["read", "list", "preview"] },
        "full_access": { "function_calling_config": { "mode": "AUTO" }, "function_declarations": ["all"] }
      },
      "notes": "Gemini may ignore system messages. Protocol is injected as the first user message instead."
    },
